// Practical Tracker — Database Schema
// Run: npx prisma db push  (development)
//      npx prisma migrate dev (production)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Auth (NextAuth compatible) ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── User & Profile ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Profile
  username      String?   @unique
  uspsa_number  String?
  scsa_number   String?
  division      String?   // Open, Carry Optics, PCC, Limited, etc.
  primaryGun    String?
  bio           String?
  isPublic      Boolean   @default(false)

  accounts     Account[]
  sessions     Session[]
  matches      Match[]
  expenses     Expense[]
  chrono       ChronoEntry[]
  maintenance  MaintenanceLog[]
  guns         Gun[]
}

// ── Guns / Builds ──────────────────────────────────────────────────────────

model Gun {
  id          String   @id @default(cuid())
  userId      String
  name        String   // e.g. "Aero EPC-9 GRS Build"
  caliber     String   // 9mm, .223, .308, etc.
  discipline  String[] // which disciplines it's used for
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches      Match[]
  expenses     Expense[]
  maintenance  MaintenanceLog[]
  chrono       ChronoEntry[]
}

// ── Matches ────────────────────────────────────────────────────────────────

model Match {
  id               String      @id @default(cuid())
  userId           String
  gunId            String?
  createdAt        DateTime    @default(now())

  date             DateTime
  club             String
  matchName        String?
  discipline       Discipline
  division         String?     // PCC, Open, CO, Limited, etc.
  tier             MatchTier   @default(LOCAL)

  placement        Int?
  totalCompetitors Int?
  percentile       Float?      // computed: (1 - placement/total) * 100

  roundsUsed       Int         @default(0)
  ammoCostPerRound Float       @default(0)

  powerFactor      Int?
  pfType           String?     // "Minor", "Major"

  dq               Boolean     @default(false)
  dqReason         String?
  notes            String?

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  gun    Gun?          @relation(fields: [gunId], references: [id])
  stages StageScore[]
  chrono ChronoEntry[]
  expenses Expense[]
}

model StageScore {
  id                    String  @id @default(cuid())
  matchId               String
  stageNum              Int
  stageName             String?
  score                 Float   @default(0)
  points                Float?
  time                  Float?
  hitFactor             Float?
  hits                  Int?
  misses                Int     @default(0)
  penalties             Int     @default(0)
  stagePlacement        Int?
  stageTotalCompetitors Int?
  classifier            Boolean @default(false)
  dnf                   Boolean @default(false)
  youtubeUrl            String?
  notes                 String?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

// ── Expenses ───────────────────────────────────────────────────────────────

model Expense {
  id        String          @id @default(cuid())
  userId    String
  gunId     String?
  matchId   String?
  createdAt DateTime        @default(now())

  date      DateTime
  category  ExpenseCategory
  item      String
  amount    Float
  vendor    String?
  url       String?
  notes     String?

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  gun  Gun?   @relation(fields: [gunId], references: [id])
  match Match? @relation(fields: [matchId], references: [id])
}

// ── Chrono / Load Development ──────────────────────────────────────────────

model ChronoEntry {
  id        String   @id @default(cuid())
  userId    String
  gunId     String?
  matchId   String?
  createdAt DateTime @default(now())

  date            DateTime
  ammoDescription String?
  bulletWeight    Float
  bulletType      String?   // FMJ, JHP, Coated, Polymer, etc.
  powder          String?
  powderCharge    Float?
  primer          String?
  oal             Float?    // Overall cartridge length in inches

  strings         Int       @default(10)
  avgVelocity     Float
  minVelocity     Float     @default(0)
  maxVelocity     Float     @default(0)
  stdDev          Float?
  extremeSpread   Float?
  powerFactor     Int       // computed: bulletWeight * avgVelocity / 1000

  notes           String?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  gun   Gun?   @relation(fields: [gunId], references: [id])
  match Match? @relation(fields: [matchId], references: [id])
}

// ── Maintenance ────────────────────────────────────────────────────────────

model MaintenanceLog {
  id        String   @id @default(cuid())
  userId    String
  gunId     String?
  createdAt DateTime @default(now())

  date                  DateTime
  roundsFired           Int      @default(0)
  totalRoundsSinceClean Int      @default(0)
  lifetimeRounds        Int      @default(0)
  action                String
  partsReplaced         String?
  partsInspected        String?
  lubricants            String?
  notes                 String?

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  gun  Gun?  @relation(fields: [gunId], references: [id])
}

// ── Enums ──────────────────────────────────────────────────────────────────

enum Discipline {
  USPSA
  SCSA       // Steel Challenge
  IPSC
  IDPA
  THREE_GUN
  PRS        // Precision Rifle Series
  NRL22
  RIMFIRE
  OTHER
}

enum MatchTier {
  LOCAL       // Weekly club match
  TIER1       // Sectional / Area
  TIER2       // State Championship
  TIER3       // Regional / National
  MAJOR       // Nationals / World Shoot
}

enum ExpenseCategory {
  PARTS
  AMMO
  RELOADING
  OPTICS
  ACCESSORIES
  MATCH_FEES
  TRAINING
  TRAVEL
  OTHER
}
