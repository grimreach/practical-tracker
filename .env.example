# ── Database ───────────────────────────────────────────────────────────────
# Recommended: Supabase (free tier), Neon, PlanetScale, or Railway
# Supabase: Settings → Database → Connection String → URI mode
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/practical_tracker?schema=public"

# ── NextAuth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-random-secret"
NEXTAUTH_URL="http://localhost:3000"
# Production: NEXTAUTH_URL="https://your-app.vercel.app"

# ── OAuth Providers (add the ones you want) ────────────────────────────────

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Optional: Email (for magic links) ──────────────────────────────────────
# EMAIL_SERVER_HOST="smtp.sendgrid.net"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="apikey"
# EMAIL_SERVER_PASSWORD=""
# EMAIL_FROM="noreply@yourdomain.com"
