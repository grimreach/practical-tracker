# ── Database ───────────────────────────────────────────────────────────────
# Recommended: Supabase (free tier), Neon, PlanetScale, or Railway
# Supabase: Settings → Database → Connection String → URI mode
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/practical_tracker?schema=public"

# ── Auth (NextAuth v5 / Auth.js, wired to these explicit names) ────────────
# Generate with: npx auth secret  (or: openssl rand -base64 32)
NEXTAUTH_SECRET="replace-with-random-secret"
# Optional. On Vercel the URL is auto-detected; set only if needed locally/proxied:
# NEXTAUTH_URL="http://localhost:3000"

# ── OAuth: GitHub — https://github.com/settings/developers ─────────────────
GITHUB_ID=""
GITHUB_SECRET=""

# To add Google later: add GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET here and
# re-add the Google provider in src/auth.ts.

# ── Optional: Email (for magic links) ──────────────────────────────────────
# EMAIL_SERVER_HOST="smtp.sendgrid.net"
# EMAIL_SERVER_PORT=587
# EMAIL_SERVER_USER="apikey"
# EMAIL_SERVER_PASSWORD=""
# EMAIL_FROM="noreply@yourdomain.com"
